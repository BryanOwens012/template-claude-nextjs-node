    "@supabase/supabase-js": "^2.108.1",
    "@trpc/server": "^11.17.0",
    "ai": "^6.0.202",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "ioredis": "^5.11.1",
    "langfuse": "^3.38.20",
    "posthog-node": "^5.36.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.9.3",
