{
  "name": "api",
  "version": "1.0.0",
  "description": "API server — Node.js + Express + TypeScript + Supabase + Redis",
  "main": "dist/api/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
