PORT=8000
NODE_ENV=development

# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxx

# Redis (Required)
REDIS_URL=redis://localhost:6379
# Railway auto-sets this when you add the Redis plugin

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Auth — Admin email domain (emails @this-domain get admin privileges)
# ADMIN_EMAIL_DOMAIN=mycompany.com

# Auth — Internal API key for server-to-server auth bypass
# INTERNAL_API_KEY=your-internal-api-key

# Auth — Dev only. Bypasses auth entirely (never enable in production)
# BYPASS_AUTH=true

# Langfuse (Optional — enables prompt management and tracing)
# Get these from https://cloud.langfuse.com/project/_/settings
# LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
# LANGFUSE_SECRET_KEY=your-langfuse-secret-key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Analytics (PostHog — optional, same project key as NEXT_PUBLIC_POSTHOG_KEY)
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com

# Anthropic (Required for AI calls — see POST /langfuse/trace-example)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional — uncomment as needed
# OPENAI_API_KEY=sk-xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# SENDGRID_API_KEY=xxxxx
# SENTRY_DSN=https://xxxxx
