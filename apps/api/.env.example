PORT=8000
NODE_ENV=development

# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxx

# Redis (Required)
REDIS_URL=redis://localhost:6379
# Railway auto-sets this when you add the Redis plugin

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Langfuse (Optional — enables prompt management and tracing)
# Get these from https://cloud.langfuse.com/project/_/settings
# LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
# LANGFUSE_SECRET_KEY=your-langfuse-secret-key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Anthropic (Required for AI calls — see POST /langfuse/trace-example)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional — uncomment as needed
# OPENAI_API_KEY=sk-xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# SENDGRID_API_KEY=xxxxx
# SENTRY_DSN=https://xxxxx
